# Configuración de la aplicación Obmgon Taxi
# Copia este archivo a .env y completa con tus claves reales

# Google Maps API Key
# Obtén tu clave en: https://console.cloud.google.com/google/maps-apis
REACT_APP_GOOGLE_MAPS_API_KEY=tu_google_maps_api_key_aqui

# Configuración del backend (opcional)
REACT_APP_BACKEND_URL=http://localhost:3001

# Configuración de WebSocket para tiempo real (opcional)
REACT_APP_WEBSOCKET_URL=ws://localhost:3001